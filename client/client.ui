<?xml version="1.0" encoding="UTF-8"?>
<!--
  client.ui -- GTK4 Builder XML layout for NodeSignal Messenger.

  Defines the complete widget tree for the client application window.
  Two pages are managed by a GtkStack with a crossfade transition:

    login_page  -- Centered card with app branding, server/port/username fields,
                   and a Connect button.  A sidebar panel at left carries the
                   NodeSignal wordmark and a short tagline.

    chat_page   -- Three-column layout: a narrow left sidebar showing the active
                   channel and connection info, a main transcript area, and an
                   input bar fixed at the bottom.

  All widget IDs referenced by client.c are preserved exactly:
    main_window, main_stack, login_page, chat_page,
    server_entry, port_entry, username_entry, message_entry,
    connect_button, send_button, status_label, transcript_view.

  Additional IDs used only for display (not referenced in C):
    chat_header_label, sidebar_status_dot, sidebar_server_label,
    sidebar_user_label, sidebar_channel_label.
-->
<interface>
  <requires lib="gtk" version="4.0"/>

  <object class="GtkApplicationWindow" id="main_window">
    <property name="title">NodeSignal Messenger</property>
    <property name="default-width">1100</property>
    <property name="default-height">720</property>
    <property name="css-classes">ns-window</property>

    <!-- ================================================================
         Header Bar
         ================================================================ -->
    <child type="titlebar">
      <object class="GtkHeaderBar" id="main_header_bar">
        <property name="show-title-buttons">True</property>
        <property name="css-classes">ns-header-bar</property>
        <property name="title-widget">
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="halign">center</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkLabel" id="chat_header_label">
                <property name="label">NodeSignal</property>
                <property name="css-classes">ns-header-title</property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </child>

    <!-- ================================================================
         Root stack: login vs. chat
         ================================================================ -->
    <child>
      <object class="GtkStack" id="main_stack">
        <property name="hexpand">True</property>
        <property name="vexpand">True</property>
        <property name="transition-type">crossfade</property>
        <property name="transition-duration">280</property>

        <!-- ============================================================
             LOGIN PAGE
             Two-column layout: left branding panel + right form card.
             ============================================================ -->
        <child>
          <object class="GtkBox" id="login_page">
            <property name="orientation">horizontal</property>
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <property name="css-classes">ns-login-root</property>

            <!-- Left branding panel -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">20</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
                <property name="css-classes">ns-login-brand-panel</property>
                <property name="margin-start">48</property>
                <property name="margin-end">48</property>
                <property name="margin-top">48</property>
                <property name="margin-bottom">48</property>

                <!-- App icon placeholder (large circle monogram) -->
                <child>
                  <object class="GtkLabel">
                    <property name="label">NS</property>
                    <property name="css-classes">ns-app-monogram</property>
                    <property name="halign">center</property>
                    <property name="margin-top">20</property>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel">
                    <property name="label">NodeSignal</property>
                    <property name="css-classes">ns-brand-wordmark</property>
                    <property name="halign">center</property>
                  </object>
                </child>

                <child>
                  <object class="GtkLabel">
                    <property name="label">Real-time TCP messaging,&#10;built from the protocol layer up.</property>
                    <property name="css-classes">ns-brand-tagline</property>
                    <property name="halign">center</property>
                    <property name="justify">center</property>
                    <property name="wrap">True</property>
                  </object>
                </child>

                <!-- Feature pills -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">10</property>
                    <property name="halign">center</property>
                    <property name="margin-top">16</property>
                    <property name="margin-bottom">20</property>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">8</property>
                        <property name="halign">start</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">&#x2022;</property>
                            <property name="css-classes">ns-feature-bullet</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Binary wire protocol with version checking</property>
                            <property name="css-classes">ns-feature-text</property>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">8</property>
                        <property name="halign">start</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">&#x2022;</property>
                            <property name="css-classes">ns-feature-bullet</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Up to 1,024 concurrent clients</property>
                            <property name="css-classes">ns-feature-text</property>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">8</property>
                        <property name="halign">start</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">&#x2022;</property>
                            <property name="css-classes">ns-feature-bullet</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">SQLite persistence layer</property>
                            <property name="css-classes">ns-feature-text</property>
                          </object>
                        </child>
                      </object>
                    </child>

                  </object>
                </child>

              </object>
            </child>

            <!-- Vertical divider -->
            <child>
              <object class="GtkSeparator">
                <property name="orientation">vertical</property>
                <property name="css-classes">ns-login-divider</property>
              </object>
            </child>

            <!-- Right form card -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
                <property name="css-classes">ns-login-form-area</property>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">0</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="css-classes">ns-login-card</property>
                    <property name="width-request">360</property>

                    <!-- Card header -->
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">6</property>
                        <property name="css-classes">ns-login-card-header</property>

                        <child>
                          <object class="GtkLabel">
                            <property name="label">Sign In</property>
                            <property name="css-classes">ns-login-card-title</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label">Connect to a NodeSignal server</property>
                            <property name="css-classes">ns-login-card-subtitle</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>

                      </object>
                    </child>

                    <!-- Divider below header -->
                    <child>
                      <object class="GtkSeparator">
                        <property name="orientation">horizontal</property>
                        <property name="css-classes">ns-card-sep</property>
                      </object>
                    </child>

                    <!-- Form body -->
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">14</property>
                        <property name="css-classes">ns-login-card-body</property>

                        <!-- Server host group -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">4</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Server Host</property>
                                <property name="css-classes">ns-field-label</property>
                                <property name="xalign">0.0</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="server_entry">
                                <property name="placeholder-text">e.g. 127.0.0.1</property>
                                <property name="text">127.0.0.1</property>
                                <property name="css-classes">ns-field-entry</property>
                                <property name="hexpand">True</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Port group -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">4</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Port</property>
                                <property name="css-classes">ns-field-label</property>
                                <property name="xalign">0.0</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="port_entry">
                                <property name="placeholder-text">e.g. 5555</property>
                                <property name="text">5555</property>
                                <property name="css-classes">ns-field-entry</property>
                                <property name="hexpand">True</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Username group -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">4</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Username</property>
                                <property name="css-classes">ns-field-label</property>
                                <property name="xalign">0.0</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkEntry" id="username_entry">
                                <property name="placeholder-text">Choose a display name</property>
                                <property name="css-classes">ns-field-entry</property>
                                <property name="max-length">32</property>
                                <property name="hexpand">True</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Status label -->
                        <child>
                          <object class="GtkLabel" id="status_label">
                            <property name="label">Enter a server and username to connect.</property>
                            <property name="css-classes">ns-status-label</property>
                            <property name="xalign">0.0</property>
                            <property name="wrap">True</property>
                          </object>
                        </child>

                        <!-- Connect button -->
                        <child>
                          <object class="GtkButton" id="connect_button">
                            <property name="label">Connect</property>
                            <property name="css-classes">ns-primary-button</property>
                            <property name="hexpand">True</property>
                          </object>
                        </child>

                      </object>
                    </child>

                  </object>
                </child>

              </object>
            </child>

          </object>
        </child>

        <!-- ============================================================
             CHAT PAGE
             Three-panel layout: narrow sidebar | main transcript | (future)
             ============================================================ -->
        <child>
          <object class="GtkBox" id="chat_page">
            <property name="orientation">horizontal</property>
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <property name="css-classes">ns-chat-root</property>

            <!-- --------------------------------------------------------
                 Left sidebar
                 -------------------------------------------------------- -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">0</property>
                <property name="width-request">220</property>
                <property name="css-classes">ns-sidebar</property>

                <!-- Sidebar header with online dot -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">8</property>
                    <property name="css-classes">ns-sidebar-header</property>
                    <property name="valign">center</property>

                    <child>
                      <object class="GtkLabel" id="sidebar_status_dot">
                        <property name="label">&#x25CF;</property>
                        <property name="css-classes">ns-online-dot</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">Connected</property>
                        <property name="css-classes">ns-sidebar-header-title</property>
                        <property name="hexpand">True</property>
                        <property name="xalign">0.0</property>
                      </object>
                    </child>

                  </object>
                </child>

                <child>
                  <object class="GtkSeparator">
                    <property name="orientation">horizontal</property>
                    <property name="css-classes">ns-sidebar-sep</property>
                  </object>
                </child>

                <!-- Channel section -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">2</property>
                    <property name="css-classes">ns-sidebar-section</property>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">CHANNEL</property>
                        <property name="css-classes">ns-sidebar-section-label</property>
                        <property name="xalign">0.0</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">8</property>
                        <property name="css-classes">ns-sidebar-channel-row ns-sidebar-channel-active</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">#</property>
                            <property name="css-classes">ns-channel-hash</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="sidebar_channel_label">
                            <property name="label">general</property>
                            <property name="css-classes">ns-channel-name</property>
                            <property name="hexpand">True</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                      </object>
                    </child>

                  </object>
                </child>

                <child>
                  <object class="GtkSeparator">
                    <property name="orientation">horizontal</property>
                    <property name="css-classes">ns-sidebar-sep</property>
                  </object>
                </child>

                <!-- Connection details section -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">6</property>
                    <property name="css-classes">ns-sidebar-section</property>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">CONNECTION</property>
                        <property name="css-classes">ns-sidebar-section-label</property>
                        <property name="xalign">0.0</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">2</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Server</property>
                            <property name="css-classes">ns-meta-key</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="sidebar_server_label">
                            <property name="label">-</property>
                            <property name="css-classes">ns-meta-value</property>
                            <property name="xalign">0.0</property>
                            <property name="wrap">True</property>
                            <property name="ellipsize">end</property>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">2</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Logged in as</property>
                            <property name="css-classes">ns-meta-key</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="sidebar_user_label">
                            <property name="label">-</property>
                            <property name="css-classes">ns-meta-value ns-meta-username</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                      </object>
                    </child>

                  </object>
                </child>

                <!-- Spacer to push user avatar to bottom -->
                <child>
                  <object class="GtkBox">
                    <property name="vexpand">True</property>
                  </object>
                </child>

                <!-- Bottom user identity row -->
                <child>
                  <object class="GtkSeparator">
                    <property name="orientation">horizontal</property>
                    <property name="css-classes">ns-sidebar-sep</property>
                  </object>
                </child>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">10</property>
                    <property name="css-classes">ns-sidebar-identity</property>
                    <property name="valign">center</property>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">NS</property>
                        <property name="css-classes">ns-avatar</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">2</property>
                        <property name="valign">center</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">NodeSignal</property>
                            <property name="css-classes">ns-identity-name</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Messenger</property>
                            <property name="css-classes">ns-identity-sub</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                      </object>
                    </child>

                  </object>
                </child>

              </object>
            </child>

            <!-- Sidebar / main separator -->
            <child>
              <object class="GtkSeparator">
                <property name="orientation">vertical</property>
                <property name="css-classes">ns-sidebar-sep</property>
              </object>
            </child>

            <!-- --------------------------------------------------------
                 Main content: transcript + input bar
                 -------------------------------------------------------- -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">0</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>

                <!-- Chat sub-header bar -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">10</property>
                    <property name="css-classes">ns-chat-subheader</property>
                    <property name="valign">center</property>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">#</property>
                        <property name="css-classes">ns-subheader-hash</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">general</property>
                        <property name="css-classes">ns-subheader-title</property>
                        <property name="hexpand">True</property>
                        <property name="xalign">0.0</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkLabel">
                        <property name="label">NodeSignal Messenger  |  TCP Chat</property>
                        <property name="css-classes">ns-subheader-meta</property>
                        <property name="xalign">1.0</property>
                      </object>
                    </child>

                  </object>
                </child>

                <child>
                  <object class="GtkSeparator">
                    <property name="orientation">horizontal</property>
                    <property name="css-classes">ns-content-sep</property>
                  </object>
                </child>

                <!-- Transcript scroll area -->
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hexpand">True</property>
                    <property name="vexpand">True</property>
                    <property name="hscrollbar-policy">never</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <property name="css-classes">ns-transcript-scroll</property>

                    <child>
                      <object class="GtkTextView" id="transcript_view">
                        <property name="editable">False</property>
                        <property name="cursor-visible">False</property>
                        <property name="wrap-mode">word-char</property>
                        <property name="left-margin">24</property>
                        <property name="right-margin">24</property>
                        <property name="top-margin">16</property>
                        <property name="bottom-margin">16</property>
                        <property name="css-classes">ns-transcript</property>
                      </object>
                    </child>

                  </object>
                </child>

                <!-- Bottom input bar -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">0</property>
                    <property name="css-classes">ns-input-bar-container</property>

                    <child>
                      <object class="GtkSeparator">
                        <property name="orientation">horizontal</property>
                        <property name="css-classes">ns-content-sep</property>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">10</property>
                        <property name="css-classes">ns-input-bar</property>
                        <property name="valign">center</property>

                        <child>
                          <object class="GtkEntry" id="message_entry">
                            <property name="hexpand">True</property>
                            <property name="placeholder-text">Message #general</property>
                            <property name="css-classes">ns-message-entry</property>
                          </object>
                        </child>

                        <child>
                          <object class="GtkButton" id="send_button">
                            <property name="label">Send</property>
                            <property name="css-classes">ns-send-button</property>
                            <property name="valign">center</property>
                          </object>
                        </child>

                      </object>
                    </child>

                  </object>
                </child>

              </object>
            </child>

          </object>
        </child>

      </object>
    </child>

  </object>
</interface>
